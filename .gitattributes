# =============================================================================
# Normalize line endings. Shell scripts and Blade/PHP templates MUST be LF —
# CRLF breaks the entrypoint on Alpine ("bad interpreter") and is unnecessary
# inside the Linux container.
# =============================================================================

# Default: let Git normalize text files to LF in the repo.
* text=auto eol=lf

# Force LF for files executed/consumed inside the container.
*.sh          text eol=lf
*.php         text eol=lf
*.blade.php   text eol=lf
*.css         text eol=lf
Dockerfile    text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf

# Binary assets — never touch.
*.png  binary
*.jpg  binary
*.woff binary
*.woff2 binary
*.ico  binary
