# =============================================================================
# LinkStack — Environment Configuration
# =============================================================================
# Self-hosted "link in bio" platform for BAUER GROUP, based on LinkStack.
#
#   Public page + Admin: https://links.bauer-group.com  (admin at /admin)
#
# Database: SQLite (default) — stored inside the /htdocs data volume. There is
# no separate database service; the whole ${STACK_NAME}-data volume is the
# backup unit (see scripts/linkstack-backup.py).
#
# Setup: cp .env.example .env && edit .env (set LINKSTACK_DOMAIN)
#        There are NO required secrets — the admin account is created in the
#        first-run web wizard.
# =============================================================================


# =============================================================================
# Stack Configuration
# =============================================================================

# Container name prefix (used for container name, volume and network names).
STACK_NAME=linkstack

# Container timezone.
# Default: Etc/UTC
TIME_ZONE=Etc/UTC


# =============================================================================
# Image Versions
# =============================================================================

# BAUER GROUP LinkStack image tag (published to GHCR by docker-release.yml).
# Used by docker-compose.traefik.yml / docker-compose.coolify.yml.
# Tags: "stable" (latest release), "latest" (HEAD of main), or SemVer "1.0.0".
# https://github.com/bauer-group/CS-LinkStack/pkgs/container/CS-LinkStack%2Flinkstack
LINKSTACK_IMAGE_TAG=stable

# Upstream LinkStack base image tag — only consumed as build-arg by
# app/linkstack/Dockerfile (FROM linkstackorg/linkstack:${LINKSTACK_VERSION}).
# Active in docker-compose.development.yml.
# Recommendation: pin a concrete SemVer (e.g. 4.8.6) for reproducible builds.
# https://hub.docker.com/r/linkstackorg/linkstack/tags
LINKSTACK_VERSION=latest


# =============================================================================
# LinkStack Application (Apache / PHP — upstream image env)
# =============================================================================

# Public domain (REQUIRED — must match DNS + the reverse proxy router).
LINKSTACK_DOMAIN=links.bauer-group.com

# Apache ServerAdmin / admin contact email.
SERVICE_ADMIN_EMAIL=info@bauer-group.com

# Apache log level (emerg, alert, crit, error, warn, notice, info, debug).
# Default: info
LINKSTACK_LOG_LEVEL=info

# PHP memory_limit.
# Default: 512M
PHP_MEMORY_LIMIT=512M

# PHP upload_max_filesize (avatars, theme uploads).
# Default: 8M
UPLOAD_MAX_FILESIZE=8M


# =============================================================================
# Managed config bootstrap (BAUER GROUP entrypoint)
# =============================================================================
# When LINKSTACK_MANAGE_ENV=true, the entrypoint MERGES the managed keys below
# into LinkStack's /htdocs/.env on every boot — editing ONLY those keys and
# preserving every other key (APP_KEY, admin settings, …). It only runs after the
# setup wizard created /htdocs/.env, and LinkStack reads .env fresh (no cache).
# Set LINKSTACK_MANAGE_ENV=false to hand full control to the admin panel.
#
# traefik/coolify default MANAGE_ENV=true; development defaults it to false.
LINKSTACK_MANAGE_ENV=true

# ── Reverse proxy ────────────────────────────────────────────────────────────
# Behind a TLS-terminating proxy, LinkStack needs FORCE_HTTPS=true to generate
# https:// URLs and avoid mixed-content errors.
LINKSTACK_FORCE_HTTPS=true

# ── Branding policy ──────────────────────────────────────────────────────────
# Show the "Powered by LinkStack" credit on all pages? Default false (hidden).
LINKSTACK_DISPLAY_CREDIT=false

# ── SMTP / e-mail (optional) ─────────────────────────────────────────────────
# Applied only when LINKSTACK_SMTP_HOST is set. Leave HOST empty to let the admin
# configure mail in the panel instead. Sets the matching MAIL_* keys in .env.
LINKSTACK_SMTP_HOST=
LINKSTACK_SMTP_PORT=587
LINKSTACK_SMTP_USERNAME=
LINKSTACK_SMTP_PASSWORD=
LINKSTACK_SMTP_ENCRYPTION=tls
LINKSTACK_SMTP_FROM_ADDRESS=no-reply@bauer-group.com
LINKSTACK_SMTP_FROM_NAME=BAUER GROUP
# LINKSTACK_SMTP_MAILER=smtp   # default 'smtp' when a host is provided


# =============================================================================
# Themes (baked into the image, no configuration needed)
# =============================================================================
# The corporate theme + curated stock themes are baked into the image and mirrored
# into /htdocs/themes on every boot (image-managed themes are refreshed, your own
# uploaded themes are preserved). There is nothing to configure here.
# The public page's avatar, footer links and the "Powered by LinkStack" credit are
# NOT theme settings — they live in the LinkStack admin panel (stored in the data
# volume) so they stay editable. See README → Themes / Branding.


# =============================================================================
# Traefik Configuration (docker-compose.traefik.yml)
# =============================================================================
# DNS record must resolve to ${LINKSTACK_DOMAIN} before starting.

# External Traefik network name (must already exist).
PROXY_NETWORK=EDGEPROXY

# Optional IP allow-list for the public page (Traefik ipallowlist middleware).
# Default allows everyone. Restrict for intranet-only deployments, e.g.:
#   IP_WHITELIST=127.0.0.1/32,::1/128,192.168.0.0/16,fd00::/8
IP_WHITELIST=0.0.0.0/0,::/0


# =============================================================================
# Port Settings (docker-compose.development.yml)
# =============================================================================
# Direct port binding when NOT using a reverse proxy.

# Host port mapped to the container's HTTP port 80.
EXPOSED_HTTP_PORT=8080


# =============================================================================
# Deployment
# =============================================================================
#
# Production + Traefik (HTTPS):
#   docker compose -f docker-compose.traefik.yml up -d
#   → https://links.bauer-group.com  (admin at /admin)
#
# Production + Coolify:
#   Deploy docker-compose.coolify.yml via the Coolify UI.
#   Set the domain in the Coolify dashboard (see file header).
#
# Development (direct port access, local build):
#   docker compose -f docker-compose.development.yml up -d
#   → http://localhost:8080
#
# First run:
#   Open the site, complete the wizard (choose SQLite → the default), create the
#   admin user, then CHANGE the default password. Select the "bauer-group" theme
#   under Admin → Themes.
#
# Documentation:
#   https://docs.linkstack.org/
#   https://docs.linkstack.org/docker/setup/
#   https://docs.linkstack.org/docker/reverse-proxies/
#
